# Auth.js
AUTH_SECRET=your-secret-here-generate-with-openssl-rand-base64-32

# GitHub OAuth
# Create at: https://github.com/settings/developers
# Callback URL: http://localhost:3000/api/auth/callback/github
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# Auth.js trust host
AUTH_TRUST_HOST=true

# Migrate secret - required to access /api/migrate?secret=xxx
MIGRATE_SECRET=generate-with-openssl-rand-base64-24

# AI quality review (submission gate)
AI_REVIEW_BASE_URL=http://changme.sbs:8317/v1
AI_REVIEW_API_KEY=replace-with-your-api-key
AI_REVIEW_MODEL=gpt-5.3-codex
